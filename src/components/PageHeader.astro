---
export interface Props {
    title: string;
    iconWrapperClasses: string;
}

const { title, iconWrapperClasses } = Astro.props;
---

<div
    class="flex flex-col items-center justify-center text-center mb-16 animate-fade-in-up"
>
    <div
        class={`w-16 h-16 flex items-center justify-center rounded-2xl mb-6 border ${iconWrapperClasses}`}
    >
        <slot name="icon" />
    </div>
    <h1
        class="text-3xl md:text-4xl font-semibold text-primary/90 mb-4 tracking-tight"
    >
        {title}
    </h1>
</div>
