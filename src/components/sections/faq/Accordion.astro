---
import { getLangFromUrl } from '@/i18n/utils'
import { faqsData } from '@/data/faqs'

const lang = getLangFromUrl(Astro.url)
const faqs = faqsData[lang]
---

<div class="rounded-xl border border-primary/10 overflow-hidden bg-white/60 dark:bg-white/[0.03]">
  {
    faqs.map((faq, idx) => (
      <details
        class={`faq-detail group${idx < faqs.length - 1 ? ' border-b border-primary/[0.06]' : ''}`}
      >
        <summary class="faq-summary flex justify-between items-center gap-4 px-6 py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none transition-colors duration-160">
          <span class="text-sm font-medium text-primary/90 leading-snug [text-wrap:pretty]">
            {faq.question}
          </span>
          <span class="faq-icon text-primary/35 shrink-0" aria-hidden="true">
            <svg
              fill="none"
              height="16"
              width="16"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </span>
        </summary>
        <div
          class="faq-content overflow-hidden"
          style="max-height: 0px; opacity: 0; transform: translateY(5px);"
        >
          <div class="px-6 py-5">
            <p class="text-sm text-primary/60 leading-relaxed font-normal [text-wrap:pretty] m-0">
              {faq.answer}
            </p>
          </div>
        </div>
      </details>
    ))
  }
</div>

<style>
  .faq-icon {
    transition: transform 200ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .faq-content {
    transition:
      max-height 240ms cubic-bezier(0.23, 1, 0.32, 1),
      opacity 200ms ease,
      transform 240ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  details summary {
    outline: none;
  }

  details summary:focus-visible {
    outline: 2px solid var(--blue-color);
    outline-offset: -2px;
    border-radius: inherit;
  }

  @media (hover: hover) and (pointer: fine) {
    .faq-summary:hover {
      background-color: color-mix(in srgb, var(--primary) 2%, transparent);
    }
    .faq-detail[open] .faq-summary {
      background-color: color-mix(in srgb, var(--primary) 2%, transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-icon {
      transition: none !important;
    }
    .faq-content {
      transition: opacity 160ms ease !important;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const detailsElements = document.querySelectorAll('.faq-detail')
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    const EASE = 'cubic-bezier(0.23, 1, 0.32, 1)'
    const OPEN_MS = 240
    const CLOSE_MS = 150

    detailsElements.forEach((detail) => {
      if (detail.hasAttribute('data-faq-init')) return
      detail.setAttribute('data-faq-init', 'true')

      const summary = detail.querySelector('summary')
      const content = detail.querySelector('.faq-content') as HTMLElement
      const icon = detail.querySelector('.faq-icon') as HTMLElement

      if (!summary || !content) return

      summary.addEventListener('click', (e) => {
        e.preventDefault()

        const isClosing = detail.hasAttribute('open')

        if (prefersReducedMotion) {
          if (isClosing) {
            detail.removeAttribute('open')
            icon.style.transform = 'rotate(0deg)'
          } else {
            detail.setAttribute('open', '')
            icon.style.transform = 'rotate(180deg)'
          }
          return
        }

        if (isClosing) {
          content.style.transition = `max-height ${CLOSE_MS}ms ${EASE}, opacity ${Math.round(CLOSE_MS * 0.8)}ms ease`
          icon.style.transition = `transform ${CLOSE_MS}ms ${EASE}`
          content.style.maxHeight = content.scrollHeight + 'px'
          void content.offsetWidth
          content.style.maxHeight = '0px'
          content.style.opacity = '0'
          content.style.transform = 'translateY(0)'
          icon.style.transform = 'rotate(0deg)'
          setTimeout(() => detail.removeAttribute('open'), CLOSE_MS)
        } else {
          detail.setAttribute('open', '')
          content.style.transition = `max-height ${OPEN_MS}ms ${EASE}, opacity ${Math.round(OPEN_MS * 0.85)}ms ease, transform ${OPEN_MS}ms ${EASE}`
          icon.style.transition = `transform ${OPEN_MS}ms ${EASE}`
          content.style.maxHeight = '0px'
          content.style.opacity = '0'
          content.style.transform = 'translateY(5px)'
          void content.offsetWidth
          content.style.maxHeight = content.scrollHeight + 'px'
          content.style.opacity = '1'
          content.style.transform = 'translateY(0)'
          icon.style.transform = 'rotate(180deg)'
          setTimeout(() => {
            content.style.maxHeight = 'none'
          }, OPEN_MS)
        }
      })
    })
  })
</script>
