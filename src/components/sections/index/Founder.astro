---
import { getLangFromUrl, useTranslations } from '@/i18n/utils'

import ButtonOutline from '@/components/ui/ButtonOutline.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="w-full mt-4 mb-16 px-6 md:px-0" id="founder" aria-labelledby="founder-title">
  <div class="max-w-175 mx-auto">
    <article
      class="flex flex-col gap-6 p-8 rounded-2xl bg-white/50 dark:bg-zinc-900/50 backdrop-blur-md border border-primary/10 dark:border-white/10 shadow-sm relative overflow-hidden hover:shadow-md hover:-translate-y-1 transition-all duration-200"
    >
      <header class="flex flex-col gap-1 relative z-10 border-b border-primary/5 pb-4 -mx-8 px-8">
        <h2
          id="founder-title"
          class="text-2xl font-bold text-primary tracking-tight"
          set:html={t('founder.title')}
        />
      </header>

      <div
        class="flex flex-col relative z-10 text-primary/80 leading-relaxed text-[0.95rem] font-normal"
      >
        <p set:html={t('founder.p1')} />
        <div
          class="mt-3 relative"
          style="-webkit-mask-image: linear-gradient(to bottom, black 10%, transparent 100%); mask-image: linear-gradient(to bottom, black 10%, transparent 100%);"
        >
          <p class="line-clamp-5 md:line-clamp-6 pb-1" set:html={t('founder.p2')} />
        </div>
      </div>

      <div class="relative z-10 flex justify-start -mt-2">
        <ButtonOutline class="py-2.5 px-6 text-[0.85rem]" data-open-modal="founder-modal">
          {t('founder.read_more')}
        </ButtonOutline>
      </div>
    </article>
  </div>
</section>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: var(--color-primary);
    opacity: 0.2;
    border-radius: 10px;
  }
</style>
