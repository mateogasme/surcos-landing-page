---
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const content = {
  es: {
    title: 'Ediciones y libros',
    items: [
      {
        title: 'Mapas para la Fiesta',
        desc: 'Nueva edición del libro. Edición propia.',
        status: 'Publicado',
        statusColor: 'emerald',
      },
      {
        title: 'Hacia una Pastoral Juvenil Orgánica',
        desc: 'Edición del texto para reflexión de grupos. Pastoral Juvenil de Zárate-Campana.',
        status: 'Publicado',
        statusColor: 'emerald',
      },
      {
        title: 'Haciendo caminos',
        desc: 'Edición en proceso.',
        status: 'En proceso',
        statusColor: 'amber',
      },
    ],
  },
  en: {
    title: 'Editions and books',
    items: [
      {
        title: 'Mapas para la Fiesta',
        desc: 'New edition of the book. Self-published.',
        status: 'Published',
        statusColor: 'emerald',
      },
      {
        title: 'Hacia una Pastoral Juvenil Orgánica',
        desc: 'Text edition for group reflection. Youth Ministry of Zárate-Campana.',
        status: 'Published',
        statusColor: 'emerald',
      },
      {
        title: 'Haciendo caminos',
        desc: 'Edition in progress.',
        status: 'In progress',
        statusColor: 'amber',
      },
    ],
  },
}

const t = content[lang]

const statusColors: Record<string, { bg: string; text: string; dot: string }> =
  {
    emerald: {
      bg: 'bg-emerald-500/10 dark:bg-emerald-500/20',
      text: 'text-emerald-600 dark:text-emerald-400',
      dot: 'bg-emerald-500',
    },
    amber: {
      bg: 'bg-amber-500/10 dark:bg-amber-500/20',
      text: 'text-amber-600 dark:text-amber-400',
      dot: 'bg-amber-500',
    },
  }
---

<section class="mb-12">
  <div
    class="rounded-2xl bg-white/50 dark:bg-zinc-900/50 border border-primary/10 dark:border-white/10 shadow-sm overflow-hidden"
  >
    <header class="px-8 pt-6 pb-4 border-b border-primary/10 dark:border-white/10">
      <h2 class="text-xl font-bold text-primary tracking-tight">
        {t.title}
      </h2>
    </header>
    <ul class="flex flex-col list-none p-0 m-0 divide-y divide-primary/5 dark:divide-white/5">
      {
        t.items.map((item) => {
          const sc = statusColors[item.statusColor] || statusColors.emerald
          return (
            <li class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6 px-7 py-5 hover:bg-primary/2 dark:hover:bg-white/2 transition-colors duration-200">
              <div class="flex items-center gap-3 shrink-0 sm:w-auto">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-primary/30 shrink-0"
                  aria-hidden="true"
                >
                  <path d="M10 2v8l3-3 3 3V2" />
                  <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
                </svg>
              </div>
              <div class="flex flex-col gap-0.5 min-w-0 flex-1">
                <strong class="text-[0.95rem] text-primary/90 leading-snug font-medium">
                  {item.title}
                </strong>
                <p class="text-[0.85rem] text-primary/55 leading-relaxed font-normal text-pretty m-0">
                  {item.desc}
                </p>
              </div>
              <div
                class={`flex items-center gap-1.5 shrink-0 px-2.5 py-1 rounded-full ${sc.bg}`}
              >
                <div
                  class={`w-1.5 h-1.5 rounded-full ${sc.dot}`}
                  aria-hidden="true"
                />
                <span
                  class={`text-[0.75rem] font-medium ${sc.text} whitespace-nowrap`}
                >
                  {item.status}
                </span>
              </div>
            </li>
          )
        })
      }
    </ul>
  </div>
</section>
