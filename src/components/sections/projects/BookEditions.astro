---
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const content = {
  es: {
    title: 'Ediciones y libros',
    items: [
      {
        title: 'Mapas para la Fiesta',
        desc: 'Nueva edición del libro. Edición propia.',
        status: 'Publicado',
        statusColor: 'emerald',
      },
      {
        title: 'Hacia una Pastoral Juvenil Orgánica',
        desc: 'Edición del texto para reflexión de grupos. Pastoral Juvenil de Zárate-Campana.',
        status: 'Publicado',
        statusColor: 'emerald',
      },
      {
        title: 'Haciendo caminos',
        desc: 'Edición en proceso.',
        status: 'En proceso',
        statusColor: 'amber',
      },
    ],
  },
  en: {
    title: 'Editions and books',
    items: [
      {
        title: 'Mapas para la Fiesta',
        desc: 'New edition of the book. Self-published.',
        status: 'Published',
        statusColor: 'emerald',
      },
      {
        title: 'Hacia una Pastoral Juvenil Orgánica',
        desc: 'Text edition for group reflection. Youth Ministry of Zárate-Campana.',
        status: 'Published',
        statusColor: 'emerald',
      },
      {
        title: 'Haciendo caminos',
        desc: 'Edition in progress.',
        status: 'In progress',
        statusColor: 'amber',
      },
    ],
  },
}

const t = content[lang]

const statusMap: Record<string, { dot: string; text: string; bg: string }> = {
  emerald: {
    dot: 'bg-emerald-500',
    text: 'text-emerald-700 dark:text-emerald-400',
    bg: 'bg-emerald-500/8 dark:bg-emerald-500/15',
  },
  amber: {
    dot: 'bg-amber-500',
    text: 'text-amber-700 dark:text-amber-400',
    bg: 'bg-amber-500/8 dark:bg-amber-500/15',
  },
}
---

<section>
  <div class="rounded-xl border border-primary/10 overflow-hidden bg-white/60 dark:bg-white/[0.03]">
    <header class="px-6 py-4 border-b border-primary/10">
      <h2 class="text-sm font-semibold text-primary tracking-tight">{t.title}</h2>
    </header>

    <ul class="divide-y divide-primary/[0.06]">
      {
        t.items.map((item) => {
          const sc = statusMap[item.statusColor] || statusMap.emerald
          return (
            <li class="flex gap-4 px-6 py-4 items-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-primary/25 shrink-0"
                aria-hidden="true"
              >
                <path d="M10 2v8l3-3 3 3V2" />
                <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
              </svg>

              <div class="flex flex-col gap-0.5 min-w-0 flex-1">
                <strong class="text-sm font-medium text-primary/90 leading-snug">
                  {item.title}
                </strong>
                <p class="text-xs text-primary/55 leading-relaxed font-normal m-0">{item.desc}</p>
              </div>

              <div
                class={`flex items-center gap-1.5 shrink-0 px-2 py-1 rounded-full ${sc.bg}`}
              >
                <div class={`w-1.5 h-1.5 rounded-full shrink-0 ${sc.dot}`} aria-hidden="true" />
                <span class={`text-[11px] font-medium whitespace-nowrap ${sc.text}`}>
                  {item.status}
                </span>
              </div>
            </li>
          )
        })
      }
    </ul>
  </div>
</section>
