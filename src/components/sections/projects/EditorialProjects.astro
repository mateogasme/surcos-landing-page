---
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const projectsLabel = (n: number) =>
  lang === 'es' ? (n === 1 ? 'proyecto' : 'proyectos') : n === 1 ? 'project' : 'projects'

const content = {
  es: {
    title: 'Proyectos editoriales institucionales',
    clients: [
      {
        name: 'Cáritas',
        color: 'blue',
        projects: [
          {
            title: 'Memoria 2007 - Encuentro nacional de directores/as',
            desc: 'Revisión y corrección de textos, diseño gráfico e impresión de la memoria del Encuentro. Impreso en Argentina.',
          },
          {
            title: 'Cáritas y Pastoral Social',
            desc: '"Tejiendo reflexiones y metodologías de equidad entre mujeres y hombres" - Documento final. Cáritas Latinoamérica (SELACC).',
          },
        ],
      },
      {
        name: 'Matt Lamb',
        color: 'amber',
        projects: [
          {
            title: 'Matt Lamb - Barcelona',
            desc: 'Diseño y puesta en imprenta del catálogo para presentaciones internacionales en el Museo Diocesano de Barcelona y el Real Círculo Artístico.',
          },
          {
            title: 'Sculptures & Millennium',
            desc: 'Diseño y puesta en imprenta del libro recordatorio para la presentación internacional.',
          },
          {
            title: 'The Barcelona Collection',
            desc: 'Diseño y puesta en imprenta del catálogo para la exposición internacional. Impreso en Italia para Europa Museum Schengen.',
          },
        ],
      },
    ],
  },
  en: {
    title: 'Institutional editorial projects',
    clients: [
      {
        name: 'Cáritas',
        color: 'blue',
        projects: [
          {
            title: 'Memoria 2007 - National Meeting of Directors',
            desc: "Text review and correction, graphic design, and printing of the Meeting's memory. Printed in Argentina.",
          },
          {
            title: 'Cáritas and Social Pastoral',
            desc: '"Weaving reflections and methodologies of equity between women and men" - Final document. Latin American Cáritas (SELACC).',
          },
        ],
      },
      {
        name: 'Matt Lamb',
        color: 'amber',
        projects: [
          {
            title: 'Matt Lamb - Barcelona',
            desc: 'Design and printing of the catalog for international presentations at the Diocesan Museum of Barcelona and the Royal Artistic Circle.',
          },
          {
            title: 'Sculptures & Millennium',
            desc: 'Design and printing of the commemorative book for the international presentation.',
          },
          {
            title: 'The Barcelona Collection',
            desc: 'Design and printing of the catalog for the international exhibition. Printed in Italy for Europa Museum Schengen.',
          },
        ],
      },
    ],
  },
}

const t = content[lang]

const colorMap: Record<string, { dot: string; text: string }> = {
  blue: { dot: 'bg-blue-500', text: 'text-blue-600 dark:text-blue-400' },
  amber: { dot: 'bg-amber-500', text: 'text-amber-600 dark:text-amber-400' },
}
---

<section>
  <div class="rounded-xl border border-primary/10 overflow-hidden bg-white/60 dark:bg-white/[0.03]">
    <header class="px-6 py-4 border-b border-primary/10">
      <h2 class="text-sm font-semibold text-primary tracking-tight">{t.title}</h2>
    </header>

    {
      t.clients.map((client, clientIdx) => {
        const colors = colorMap[client.color] || colorMap.blue
        return (
          <>
            {clientIdx > 0 && <div class="border-t border-primary/10" />}

            <div class="flex items-center gap-2.5 px-6 py-3 bg-primary/[0.02]">
              <div class={`w-1.5 h-1.5 rounded-full shrink-0 ${colors.dot}`} aria-hidden="true" />
              <span class={`text-xs font-semibold ${colors.text}`}>{client.name}</span>
              <span class="text-xs text-primary/35 ml-auto tabular-nums">
                {client.projects.length} {projectsLabel(client.projects.length)}
              </span>
            </div>

            <ul class="divide-y divide-primary/[0.06]">
              {client.projects.map((project) => (
                <li class="flex gap-4 px-6 py-4 items-start">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-primary/25 shrink-0 mt-0.5"
                    aria-hidden="true"
                  >
                    <path d="M10 2v8l3-3 3 3V2" />
                    <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
                  </svg>
                  <div class="flex flex-col gap-0.5 min-w-0">
                    <strong class="text-sm font-medium text-primary/90 leading-snug">
                      {project.title}
                    </strong>
                    <p class="text-xs text-primary/55 leading-relaxed font-normal text-pretty m-0">
                      {project.desc}
                    </p>
                  </div>
                </li>
              ))}
            </ul>
          </>
        )
      })
    }
  </div>
</section>
