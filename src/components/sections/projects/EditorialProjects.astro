---
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const content = {
  es: {
    title: 'Proyectos editoriales institucionales',
    clients: [
      {
        name: 'Cáritas',
        color: 'blue',
        projects: [
          {
            title: 'Memoria 2007 - Encuentro nacional de directores/as',
            desc: 'Revisión y corrección de textos, diseño gráfico e impresión de la memoria del Encuentro. Impreso en Argentina.',
          },
          {
            title: 'Cáritas y Pastoral Social',
            desc: '"Tejiendo reflexiones y metodologías de equidad entre mujeres y hombres" - Documento final. Cáritas Latinoamérica (SELACC).',
          },
        ],
      },
      {
        name: 'Matt Lamb',
        color: 'amber',
        projects: [
          {
            title: 'Matt Lamb - Barcelona',
            desc: 'Diseño y puesta en imprenta del catálogo para presentaciones internacionales en el Museo Diocesano de Barcelona y el Real Círculo Artístico.',
          },
          {
            title: 'Sculptures & Millennium',
            desc: 'Diseño y puesta en imprenta del libro recordatorio para la presentación internacional.',
          },
          {
            title: 'The Barcelona Collection',
            desc: 'Diseño y puesta en imprenta del catálogo para la exposición internacional. Impreso en Italia para Europa Museum Schengen.',
          },
        ],
      },
    ],
  },
  en: {
    title: 'Institutional editorial projects',
    clients: [
      {
        name: 'Cáritas',
        color: 'blue',
        projects: [
          {
            title: 'Memoria 2007 - National Meeting of Directors',
            desc: "Text review and correction, graphic design, and printing of the Meeting's memory. Printed in Argentina.",
          },
          {
            title: 'Cáritas and Social Pastoral',
            desc: '"Weaving reflections and methodologies of equity between women and men" - Final document. Latin American Cáritas (SELACC).',
          },
        ],
      },
      {
        name: 'Matt Lamb',
        color: 'amber',
        projects: [
          {
            title: 'Matt Lamb - Barcelona',
            desc: 'Design and printing of the catalog for international presentations at the Diocesan Museum of Barcelona and the Royal Artistic Circle.',
          },
          {
            title: 'Sculptures & Millennium',
            desc: 'Design and printing of the commemorative book for the international presentation.',
          },
          {
            title: 'The Barcelona Collection',
            desc: 'Design and printing of the catalog for the international exhibition. Printed in Italy for Europa Museum Schengen.',
          },
        ],
      },
    ],
  },
}

const t = content[lang]

const colorMap: Record<string, { bg: string; text: string; dot: string }> = {
  blue: {
    bg: 'bg-blue-500/10 dark:bg-blue-500/20',
    text: 'text-blue-600 dark:text-blue-400',
    dot: 'bg-blue-500',
  },
  amber: {
    bg: 'bg-amber-500/10 dark:bg-amber-500/20',
    text: 'text-amber-600 dark:text-amber-400',
    dot: 'bg-amber-500',
  },
}
---

<section>
  <div class="rounded-2xl bg-white/50 dark:bg-zinc-900/50 border border-primary/10 dark:border-white/10 shadow-sm transition-all duration-200 overflow-hidden">
    <header class="px-8 pt-6 pb-4 border-b border-primary/10 dark:border-white/10">
      <h2 class="text-xl font-bold text-primary tracking-tight">
        {t.title}
      </h2>
    </header>
    {
      t.clients.map((client, clientIdx) => {
        const colors = colorMap[client.color] || colorMap.blue
        return (
          <>
            {/* Divider between clients — full width, edge to edge */}
            {clientIdx > 0 && (
              <div class="border-t border-primary/10 dark:border-white/10" />
            )}

            {/* Client header */}
            <div class="flex items-center gap-3 px-8 pt-7 pb-4">
              <div
                class={`w-2 h-2 rounded-full ${colors.dot} shrink-0`}
                aria-hidden="true"
              />
              <h3 class="text-lg font-semibold text-primary/90 leading-snug">
                {client.name}
              </h3>
              <span class="text-xs font-medium text-primary/40 ml-auto tabular-nums">
                {client.projects.length}{' '}
                {client.projects.length === 1
                  ? lang === 'es'
                    ? 'proyecto'
                    : 'project'
                  : lang === 'es'
                    ? 'proyectos'
                    : 'projects'}
              </span>
            </div>

            {/* Projects list */}
            <div class="px-8 pb-7">
              <ul class="flex flex-col gap-0 list-none p-0 m-0">
                {client.projects.map((project, idx) => (
                  <li
                    class={`flex gap-4 py-4 ${idx !== client.projects.length - 1 ? 'border-b border-primary/5 dark:border-white/5' : ''}`}
                  >
                    <div
                      class={`w-7 h-7 flex items-center justify-center rounded-lg ${colors.bg} ${colors.text} text-xs font-semibold shrink-0 mt-0.5`}
                      aria-hidden="true"
                    >
                      {idx + 1}
                    </div>
                    <div class="flex flex-col gap-1 min-w-0">
                      <strong class="text-[0.95rem] text-primary/90 leading-snug font-medium">
                        {project.title}
                      </strong>
                      <p class="text-[0.875rem] text-primary/60 leading-relaxed font-normal text-pretty m-0">
                        {project.desc}
                      </p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </>
        )
      })
    }
  </div>
</section>
