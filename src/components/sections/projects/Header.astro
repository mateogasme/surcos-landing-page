---
import PageHeader from '@/components/ui/PageHeader.astro'
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const content = {
  es: {
    title1: 'Generamos impacto en cada comunidad.',
    title2: 'Descubrí nuestros proyectos más destacados.',
  },
  en: {
    title1: 'We generate impact in every community.',
    title2: 'Discover our most outstanding projects.',
  },
}

const t = content[lang]
---

<PageHeader title1={t.title1} title2={t.title2} />
