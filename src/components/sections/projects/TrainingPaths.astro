---
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const icons = [
  // Cáritas Perú — globe/world
  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  // Crecer desde el trabajo — sprout/growth
  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></svg>`,
  // Referentes — users
  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  // Voluntariado — heart handshake
  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08c.82.82 2.13.85 3 .07l2.07-1.9a2.82 2.82 0 0 1 3.79 0l2.96 2.66"/><path d="m18 15-2-2"/><path d="m15 18-2-2"/></svg>`,
]

const colors = [
  {
    bg: 'bg-emerald-500/10 dark:bg-emerald-500/20',
    text: 'text-emerald-600 dark:text-emerald-400',
  },
  {
    bg: 'bg-orange-500/10 dark:bg-orange-500/20',
    text: 'text-orange-600 dark:text-orange-400',
  },
  {
    bg: 'bg-purple-500/10 dark:bg-purple-500/20',
    text: 'text-purple-600 dark:text-purple-400',
  },
  {
    bg: 'bg-blue-500/10 dark:bg-blue-500/20',
    text: 'text-blue-600 dark:text-blue-400',
  },
]

const content = {
  es: {
    title: 'Itinerarios y recursos formativos',
    items: [
      {
        title: 'Formación Cáritas Perú',
        desc: 'Serie de encuentros y aportes temáticos sobre la comunicación en Cáritas.',
      },
      {
        title: 'Crecer desde el trabajo',
        desc: 'Itinerario formativo de adultos para emprendimientos cooperativos. Cáritas Zárate.',
      },
      {
        title: 'Referentes de comunicación',
        desc: 'Proceso anual semi presencial para voluntarios de Patagonia Comahue.',
      },
      {
        title: 'Voluntariado social',
        desc: 'Capacitación presencial para el voluntariado de Cáritas Zárate Campana.',
      },
    ],
  },
  en: {
    title: 'Formative itineraries and resources',
    items: [
      {
        title: 'Cáritas Peru Training',
        desc: 'Series of meetings and thematic contributions on communication in Cáritas.',
      },
      {
        title: 'Growing from Work',
        desc: 'Adult training itinerary for cooperative ventures. Cáritas Zárate.',
      },
      {
        title: 'Communication References',
        desc: 'Annual semi-presential process for volunteers of Patagonia Comahue.',
      },
      {
        title: 'Social Volunteering',
        desc: 'In-person training for volunteering in Cáritas Zárate Campana.',
      },
    ],
  },
}

const t = content[lang]
---

<section>
  <h2 class="text-xl font-bold text-primary tracking-tight mb-6">
    {t.title}
  </h2>

  <ul class="grid grid-cols-1 md:grid-cols-2 gap-5 list-none p-0 m-0">
    {
      t.items.map((item, idx) => {
        const color = colors[idx % colors.length]
        return (
          <li class="flex flex-col gap-4 p-7 rounded-2xl bg-white/50 dark:bg-zinc-900/50 border border-primary/10 dark:border-white/10 shadow-sm">
            <div
              class={`w-11 h-11 flex items-center justify-center rounded-xl ${color.bg} ${color.text} shrink-0`}
              aria-hidden="true"
            >
              <span set:html={icons[idx]} />
            </div>
            <div class="flex flex-col gap-1.5">
              <strong class="text-[1.05rem] text-primary/90 leading-snug font-semibold">
                {item.title}
              </strong>
              <p class="text-[0.875rem] text-primary/60 leading-relaxed font-normal text-pretty m-0">
                {item.desc}
              </p>
            </div>
          </li>
        )
      })
    }
  </ul>
</section>
