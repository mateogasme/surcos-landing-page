---
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const icons = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08c.82.82 2.13.85 3 .07l2.07-1.9a2.82 2.82 0 0 1 3.79 0l2.96 2.66"/><path d="m18 15-2-2"/><path d="m15 18-2-2"/></svg>`,
]

const content = {
  es: {
    title: 'Itinerarios y recursos formativos',
    items: [
      {
        title: 'Formación Cáritas Perú',
        desc: 'Serie de encuentros y aportes temáticos sobre la comunicación en Cáritas.',
      },
      {
        title: 'Crecer desde el trabajo',
        desc: 'Itinerario formativo de adultos para emprendimientos cooperativos. Cáritas Zárate.',
      },
      {
        title: 'Referentes de comunicación',
        desc: 'Proceso anual semi presencial para voluntarios de Patagonia Comahue.',
      },
      {
        title: 'Voluntariado social',
        desc: 'Capacitación presencial para el voluntariado de Cáritas Zárate Campana.',
      },
    ],
  },
  en: {
    title: 'Formative itineraries and resources',
    items: [
      {
        title: 'Cáritas Peru Training',
        desc: 'Series of meetings and thematic contributions on communication in Cáritas.',
      },
      {
        title: 'Growing from Work',
        desc: 'Adult training itinerary for cooperative ventures. Cáritas Zárate.',
      },
      {
        title: 'Communication References',
        desc: 'Annual semi-presential process for volunteers of Patagonia Comahue.',
      },
      {
        title: 'Social Volunteering',
        desc: 'In-person training for volunteering in Cáritas Zárate Campana.',
      },
    ],
  },
}

const t = content[lang]
---

<section>
  <div class="rounded-xl border border-primary/10 overflow-hidden bg-white/60 dark:bg-white/[0.03]">
    <header class="px-6 py-4 border-b border-primary/10">
      <h2 class="text-sm font-semibold text-primary tracking-tight">{t.title}</h2>
    </header>

    <ul class="divide-y divide-primary/[0.06]">
      {
        t.items.map((item, idx) => (
          <li class="flex gap-4 px-6 py-4 items-start">
            <div
              class="w-8 h-8 flex items-center justify-center rounded-lg bg-primary/[0.06] text-primary/50 shrink-0 mt-0.5"
              aria-hidden="true"
              set:html={icons[idx]}
            />
            <div class="flex flex-col gap-0.5 min-w-0 pt-1">
              <strong class="text-sm font-medium text-primary/90 leading-snug">{item.title}</strong>
              <p class="text-xs text-primary/55 leading-relaxed font-normal text-pretty m-0">
                {item.desc}
              </p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
