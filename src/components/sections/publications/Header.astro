---
import PageHeader from '@/components/ui/PageHeader.astro'
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const content = {
  es: {
    title1: 'Promovemos el conocimiento y la investigación.',
    title2: 'Explorá nuestras publicaciones y recursos.',
  },
  en: {
    title1: 'We promote knowledge and research.',
    title2: 'Explore our publications and resources.',
  },
}

const t = content[lang]
---

<PageHeader title1={t.title1} title2={t.title2} />
