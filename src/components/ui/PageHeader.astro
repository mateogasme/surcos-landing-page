---
export interface Props {
  title1: string
  title2: string
}

const { title1, title2 } = Astro.props
---

<header class="w-full mb-8 border-b border-primary/10 dark:border-white/10 pb-6">
  <h1 class="text-2xl md:text-3xl font-semibold dark:font-semibold tracking-tight text-left text-balance leading-snug">
    <span class="text-primary/60">{title1} </span>
    <span class="text-primary">{title2}</span>
  </h1>
</header>
