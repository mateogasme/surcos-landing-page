---
import Layout from '@/layouts/Layout.astro'

import ConsultingHeader from '@/sections/consulting/Header.astro'
import ConsultingServices from '@/sections/consulting/ServicesList.astro'
import Contact from '@/sections/index/Contact.astro'

import { getLangFromUrl, useTranslations } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const SITE_URL = import.meta.env.SITE ?? 'https://www.equiposurcos.com.ar'
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString()

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${SITE_URL}/en`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t('meta.consultoria.title'),
      item: canonicalUrl,
    },
  ],
})
---

<Layout
  title={t('meta.consultoria.title') as string}
  description={t('meta.consultoria.description') as string}
>
  <script type="application/ld+json" slot="jsonld" set:html={breadcrumbSchema} />
  <main class="w-full flex justify-center items-center flex-col px-6 md:px-0">
    <div class="max-w-175 w-full mt-12 mb-12">
      <ConsultingHeader />
      <ConsultingServices />
    </div>
    <Contact />
  </main>
</Layout>
