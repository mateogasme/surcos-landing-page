---
import Layout from '@/layouts/Layout.astro'
import Contact from '@/sections/Contact.astro'

import FAQHeader from '@/sections/faq/Header.astro'
import Accordion from '@/sections/faq/Accordion.astro'

import { getLangFromUrl, useTranslations } from '@/i18n/utils'
import { faqsData } from '@/data/faqs'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const faqs = faqsData[lang]

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
})
---

<Layout title={t('meta.faq.title') as string} description={t('meta.faq.description') as string}>
  <script type="application/ld+json" slot="jsonld" set:html={faqSchema} />
  <main class="w-full flex justify-center items-center flex-col px-6 md:px-0">
    <div class="max-w-175 w-full mt-12 mb-12">
      <FAQHeader />
      <Accordion />
    </div>
    <Contact />
  </main>
</Layout>
