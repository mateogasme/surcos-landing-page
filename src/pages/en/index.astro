---
import Layout from '@/layouts/Layout.astro'
import Hero from '@/components/sections/index/Hero.astro'
import About from '@/components/sections/index/About.astro'
import Friends from '@/components/sections/index/Friends.astro'
import Founder from '@/components/sections/index/Founder.astro'
import Contact from '@/components/sections/index/Contact.astro'
import { getLangFromUrl, useTranslations } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const SITE_URL = import.meta.env.SITE ?? 'https://www.equiposurcos.com.ar'

const personSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Juan Pablo Gasme',
  jobTitle: t('founder.title'),
  worksFor: {
    '@type': 'Organization',
    name: 'Equipo Surcos',
    url: SITE_URL,
  },
  affiliation: [
    {
      '@type': 'Organization',
      name: 'Cáritas Argentina',
      url: 'https://caritas.org.ar/',
    },
    { '@type': 'Organization', name: 'Fundación Educación y Misión' },
    {
      '@type': 'Organization',
      name: 'Cáritas Internationalis',
      url: 'https://www.caritas.org/',
    },
  ],
  knowsAbout: [
    'Educational consulting',
    'Youth ministry',
    'Community development',
    'Social projects',
  ],
  url: `${SITE_URL}/en`,
})
---

<Layout title={t('meta.home.title') as string} description={t('meta.home.description') as string}>
  <script type="application/ld+json" slot="jsonld" set:html={personSchema} />
  <main class="w-full flex justify-center items-center flex-col">
    <Hero />
    <About />
    <Friends />
    <Founder />
    <Contact />
  </main>
</Layout>
