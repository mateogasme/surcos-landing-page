---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
    class="w-full mb-16 px-6 md:px-0"
    id="contact"
    aria-labelledby="contact-heading"
>
    <div class="max-w-175 mx-auto">
        <div
            class="relative w-full rounded-2xl overflow-hidden bg-white/50 dark:bg-zinc-900/50 backdrop-blur-md border border-primary/10 dark:border-white/10 shadow-sm animate-fade-in-up p-8 flex flex-col md:flex-row gap-8 items-center hover:shadow-md hover:-translate-y-1 transition-all duration-200"
        >
            <!-- Texto Izquierda -->
            <div
                class="w-full md:w-[45%] flex flex-col items-center md:items-start text-center md:text-left gap-4"
            >
                <h2
                    id="contact-heading"
                    class="text-2xl lg:text-3xl font-bold text-primary tracking-tight leading-[1.15]"
                >
                    {t("contact.subtitle")}
                </h2>
                <p
                    class="text-primary/70 text-[0.95rem] leading-relaxed text-pretty"
                >
                    {t("contact.text")}
                </p>
            </div>

            <!-- Botones Derecha -->
            <div class="w-full md:w-[55%] flex flex-col gap-3">
                <!-- WhatsApp (Escribinos) -->
                <a
                    href="https://wa.me/5491162596258"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group relative flex items-center justify-between p-4 rounded-xl bg-white dark:bg-zinc-800 border border-primary/5 dark:border-white/10 transition-all duration-200 overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-0.5 w-full"
                    aria-label="WhatsApp: +54 9 11 6259-6258"
                >
                    <div class="flex items-center gap-4 relative z-10 w-full">
                        <div
                            class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-emerald-500/10 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-200"
                            aria-hidden="true"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                stroke-width="2"
                                stroke="currentColor"
                                fill="none"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"
                                ></path><path
                                    d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"
                                ></path></svg
                            >
                        </div>
                        <div class="flex flex-col text-left flex-1 min-w-0">
                            <span
                                class="text-primary font-semibold text-[0.95rem] truncate"
                                >{t("contact.whatsapp")}</span
                            >
                            <span
                                class="text-primary/60 text-[0.85rem] font-medium tracking-wide truncate"
                                >+54 9 11 6259-6258</span
                            >
                        </div>
                        <div
                            class="relative shrink-0 flex items-center justify-center w-8 h-8 rounded-lg text-primary/40 group-hover:text-primary transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                                ></path><polyline points="15 3 21 3 21 9"
                                ></polyline><line x1="10" y1="14" x2="21" y2="3"
                                ></line></svg
                            >
                        </div>
                    </div>
                </a>

                <!-- Email (Copiar) -->
                <button
                    class="copy-btn group relative flex items-center justify-between p-4 rounded-xl bg-white dark:bg-zinc-800 border border-primary/5 dark:border-white/10 transition-all duration-200 overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-0.5 w-full text-left cursor-pointer"
                    data-copy="info@equiposurcos.com.ar"
                    aria-label="Copiar email: info@equiposurcos.com.ar"
                >
                    <div class="flex items-center gap-4 relative z-10 w-full">
                        <div
                            class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-blue-500/10 dark:bg-blue-500/20 text-blue-600 dark:text-blue-400 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-200"
                            aria-hidden="true"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect width="20" height="16" x="2" y="4" rx="2"
                                ></rect><path
                                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                                ></path></svg
                            >
                        </div>
                        <div class="flex flex-col text-left flex-1 min-w-0">
                            <span
                                class="text-primary font-semibold text-[0.95rem] truncate"
                                >{t("contact.email")}</span
                            >
                            <span
                                class="text-primary/60 text-[0.85rem] font-medium tracking-wide truncate"
                                >info@equiposurcos.com.ar</span
                            >
                        </div>

                        <!-- Tooltip Copy Container -->
                        <div
                            class="relative shrink-0 flex items-center justify-center w-8 h-8 rounded-lg text-primary/40 group-hover:text-primary transition-colors"
                        >
                            <svg
                                class="icon-copy block"
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect
                                    width="14"
                                    height="14"
                                    x="8"
                                    y="8"
                                    rx="2"
                                    ry="2"></rect><path
                                    d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                                ></path></svg
                            >
                            <svg
                                class="icon-check hidden text-emerald-500"
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M20 6 9 17l-5-5"></path></svg
                            >

                            <span
                                class="tooltip-text absolute right-full mr-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none flex items-center bg-primary text-secondary text-[11px] font-medium rounded-md shadow-lg z-10 px-2.5 py-1.5 whitespace-nowrap"
                            >
                                {t("modal.copy")}
                                <span
                                    class="absolute top-1/2 left-full -translate-y-1/2 border-4 border-transparent border-l-primary"
                                ></span>
                            </span>
                            <span
                                class="tooltip-copied absolute right-full mr-2 opacity-0 pointer-events-none flex items-center bg-emerald-500 text-white text-[11px] font-medium rounded-md shadow-lg z-10 px-2.5 py-1.5 whitespace-nowrap"
                            >
                                {t("modal.copied")}
                                <span
                                    class="absolute top-1/2 left-full -translate-y-1/2 border-4 border-transparent border-l-emerald-500"
                                ></span>
                            </span>
                        </div>
                    </div>
                </button>

                <!-- Phone (Copiar) -->
                <button
                    class="copy-btn group relative flex items-center justify-between p-4 rounded-xl bg-white dark:bg-zinc-800 border border-primary/5 dark:border-white/10 transition-all duration-200 overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-0.5 w-full text-left cursor-pointer"
                    data-copy="+54 9 11 6259-6258"
                    aria-label="Copiar teléfono: +54 9 11 6259-6258"
                >
                    <div class="flex items-center gap-4 relative z-10 w-full">
                        <div
                            class="shrink-0 w-10 h-10 flex items-center justify-center rounded-lg bg-amber-500/10 dark:bg-amber-500/20 text-amber-600 dark:text-amber-400 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-200"
                            aria-hidden="true"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                                ></path></svg
                            >
                        </div>
                        <div class="flex flex-col text-left flex-1 min-w-0">
                            <span
                                class="text-primary font-semibold text-[0.95rem] truncate"
                                >{t("contact.phone")}</span
                            >
                            <span
                                class="text-primary/60 text-[0.85rem] font-medium tracking-wide truncate"
                                >+54 9 11 6259-6258</span
                            >
                        </div>

                        <!-- Tooltip Copy Container -->
                        <div
                            class="relative shrink-0 flex items-center justify-center w-8 h-8 rounded-lg text-primary/40 group-hover:text-primary transition-colors"
                        >
                            <svg
                                class="icon-copy block"
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect
                                    width="14"
                                    height="14"
                                    x="8"
                                    y="8"
                                    rx="2"
                                    ry="2"></rect><path
                                    d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                                ></path></svg
                            >
                            <svg
                                class="icon-check hidden text-emerald-500"
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M20 6 9 17l-5-5"></path></svg
                            >

                            <span
                                class="tooltip-text absolute right-full mr-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none flex items-center bg-primary text-secondary text-[11px] font-medium rounded-md shadow-lg z-10 px-2.5 py-1.5 whitespace-nowrap"
                            >
                                {t("modal.copy")}
                                <span
                                    class="absolute top-1/2 left-full -translate-y-1/2 border-4 border-transparent border-l-primary"
                                ></span>
                            </span>
                            <span
                                class="tooltip-copied absolute right-full mr-2 opacity-0 pointer-events-none flex items-center bg-emerald-500 text-white text-[11px] font-medium rounded-md shadow-lg z-10 px-2.5 py-1.5 whitespace-nowrap"
                            >
                                {t("modal.copied")}
                                <span
                                    class="absolute top-1/2 left-full -translate-y-1/2 border-4 border-transparent border-l-emerald-500"
                                ></span>
                            </span>
                        </div>
                    </div>
                </button>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const copyBtns = document.querySelectorAll(".copy-btn");

        copyBtns.forEach((btn) => {
            btn.addEventListener("click", async (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const textToCopy = target.getAttribute("data-copy");

                if (textToCopy) {
                    try {
                        await navigator.clipboard.writeText(textToCopy);

                        const iconCopy = target.querySelector(".icon-copy");
                        const iconCheck = target.querySelector(".icon-check");
                        const tooltipText =
                            target.querySelector(".tooltip-text");
                        const tooltipCopied =
                            target.querySelector(".tooltip-copied");

                        iconCopy?.classList.add("hidden");
                        iconCopy?.classList.remove("block");
                        iconCheck?.classList.remove("hidden");
                        iconCheck?.classList.add("block");

                        tooltipText?.classList.add("hidden");
                        tooltipText?.classList.remove("flex");
                        tooltipCopied?.classList.remove("opacity-0");
                        tooltipCopied?.classList.add("opacity-100");

                        setTimeout(() => {
                            iconCheck?.classList.add("hidden");
                            iconCheck?.classList.remove("block");
                            iconCopy?.classList.remove("hidden");
                            iconCopy?.classList.add("block");

                            tooltipCopied?.classList.add("opacity-0");
                            tooltipCopied?.classList.remove("opacity-100");
                            tooltipText?.classList.remove("hidden");
                            tooltipText?.classList.add("flex");
                        }, 2000);
                    } catch (err) {
                        console.error("Error al copiar: ", err);
                    }
                }
            });
        });
    });
</script>
