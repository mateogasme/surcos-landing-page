---
import CloseIcon from "@/assets/icons/ui/close.svg";
import MenuIcon from "@/assets/icons/ui/menu.svg";
import MoonIcon from "@/assets/icons/ui/moon.svg";
import SunIcon from "@/assets/icons/ui/sun.svg";

import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const targetLang = lang === "es" ? "en" : "es";

let route = Astro.url.pathname;

if (route.startsWith(`/${lang}/`)) {
    route = route.replace(`/${lang}/`, "/");
} else if (route === `/${lang}`) {
    route = "/";
}

const toggleUrl = getRelativeLocaleUrl(targetLang, route);
---

<header
    class="sticky top-0 z-50 w-full bg-secondary md:bg-secondary/80 md:backdrop-blur-md border-b border-primary/4 transition-colors duration-200"
>
    <div
        class="flex items-center justify-between w-full h-16 max-w-175 px-6 md:px-0 mx-auto"
    >
        <button
            id="mobile-menu-toggle"
            aria-controls="main-nav"
            aria-expanded="false"
            aria-label="Abrir menú de navegación"
            class="md:hidden flex items-center justify-center w-8 h-8 rounded-lg text-primary/60 hover:text-primary hover:bg-primary/5 transition-all outline-none"
        >
            <MenuIcon id="menu-icon" class="block" aria-hidden="true" />
            <CloseIcon id="close-icon" class="hidden" aria-hidden="true" />
        </button>

        <!-- Navegación -->
        <nav
            id="main-nav"
            aria-label="Principal"
            class="flex opacity-0 pointer-events-none -translate-y-2 md:translate-y-0 md:opacity-100 md:pointer-events-auto transition-all duration-200 md:transition-none flex-1 absolute md:static top-full left-0 w-full md:w-auto bg-secondary border-b border-primary/4 md:bg-transparent md:border-none md:backdrop-blur-none px-6 py-5 md:p-0 shadow-2xl shadow-black/10 md:shadow-none z-40"
        >
            <ul
                class="flex flex-col md:flex-row items-start md:items-center gap-5 md:gap-5 text-base md:text-sm font-medium"
            >
                <li>
                    <a
                        href={getRelativeLocaleUrl(lang, "/")}
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm"
                    >
                        {t("nav.home")}
                    </a>
                </li>
                <li>
                    <a
                        href={getRelativeLocaleUrl(lang, "consultoria")}
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm"
                    >
                        {t("nav.consulting")}
                    </a>
                </li>
                <li>
                    <a
                        href={getRelativeLocaleUrl(lang, "formacion")}
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm"
                    >
                        {t("nav.training")}
                    </a>
                </li>
                <li>
                    <a
                        href={getRelativeLocaleUrl(lang, "publicaciones")}
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm"
                    >
                        {t("nav.publications")}
                    </a>
                </li>
                <li>
                    <a
                        href={getRelativeLocaleUrl(lang, "trabajos")}
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm"
                    >
                        {t("nav.works")}
                    </a>
                </li>
                <li>
                    <a
                        href={getRelativeLocaleUrl(lang, "faq")}
                        class="text-primary/60 hover:text-primary transition-colors block py-2 md:inline-block md:py-1 outline-none focus-visible:ring-2 focus-visible:ring-blue focus-visible:ring-offset-2 focus-visible:ring-offset-secondary rounded-sm"
                    >
                        {t("nav.faq")}
                    </a>
                </li>
            </ul>
        </nav>

        <nav
            aria-label={lang === "es" ? "Ajustes" : "Settings"}
            class="flex items-center gap-2"
        >
            <!-- Botón de Idioma -->
            <div class="relative group/lang flex">
                <a
                    href={toggleUrl}
                    id="lang-toggle"
                    aria-label={t("lang.tooltip")}
                    class="flex items-center justify-center w-8 h-8 rounded-lg text-primary/60 hover:text-primary hover:bg-primary/5 transition-all outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-secondary text-xs font-bold tracking-wide select-none active:scale-95 cursor-default"
                >
                    <span
                        id="lang-text"
                        class="pointer-events-none"
                        aria-hidden="true"
                    >
                        {targetLang.toUpperCase()}
                    </span>
                </a>

                <!-- Tooltip -->
                <span
                    class="absolute top-full left-1/2 -translate-x-1/2 mt-2 opacity-0 group-hover/lang:opacity-100 group-focus-within/lang:opacity-100 transition-opacity duration-200 pointer-events-none flex items-center bg-primary text-secondary text-[11px] font-medium rounded-md shadow-lg z-10 px-2.5 py-1.5 min-w-max"
                >
                    <span id="lang-tooltip-text">{t("lang.tooltip")}</span>
                    <span
                        class="absolute bottom-full left-1/2 -translate-x-1/2 border-4 border-transparent border-b-primary"
                    ></span>
                </span>
            </div>

            <!-- Botón de Tema a la derecha -->
            <button
                id="theme-toggle"
                aria-label="Alternar modo oscuro"
                class="flex items-center justify-center w-8 h-8 rounded-lg text-primary/60 hover:text-primary hover:bg-primary/5 transition-all outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-secondary select-none active:scale-95 cursor-default"
            >
                <MoonIcon id="moon-icon" class="block" aria-hidden="true" />
                <SunIcon id="sun-icon" class="hidden" aria-hidden="true" />
            </button>
        </nav>
    </div>
</header>

<script>
    document.addEventListener("astro:page-load", () => {
        const themeToggle = document.getElementById("theme-toggle");
        const moonIcon = document.getElementById("moon-icon");
        const sunIcon = document.getElementById("sun-icon");

        const updateIcons = (isDark: boolean) => {
            if (!moonIcon || !sunIcon) return;
            if (isDark) {
                moonIcon.classList.add("hidden");
                moonIcon.classList.remove("block");
                sunIcon.classList.add("block");
                sunIcon.classList.remove("hidden");
            } else {
                moonIcon.classList.add("block");
                moonIcon.classList.remove("hidden");
                sunIcon.classList.add("hidden");
                sunIcon.classList.remove("block");
            }
        };

        const handleToggleClick = () => {
            const element = document.documentElement;
            element.classList.toggle("dark");
            const isDark = element.classList.contains("dark");
            localStorage.setItem("theme", isDark ? "dark" : "light");
            updateIcons(isDark);
        };

        themeToggle?.addEventListener("click", handleToggleClick);

        // Revisar el tema activo al cargar la página (Layout.astro script)
        if (document.documentElement.classList.contains("dark")) {
            updateIcons(true);
        }

        // Lógica del menú móvil
        const mobileMenuToggle = document.getElementById("mobile-menu-toggle");
        const mainNav = document.getElementById("main-nav");
        const menuIconToggle = document.getElementById("menu-icon");
        const closeIconToggle = document.getElementById("close-icon");

        mobileMenuToggle?.addEventListener("click", () => {
            const isExpanded =
                mobileMenuToggle.getAttribute("aria-expanded") === "true";
            mobileMenuToggle.setAttribute("aria-expanded", String(!isExpanded));

            if (isExpanded) {
                // Cerrar menú
                mainNav?.classList.add(
                    "opacity-0",
                    "pointer-events-none",
                    "-translate-y-2",
                );
                mainNav?.classList.remove(
                    "opacity-100",
                    "pointer-events-auto",
                    "translate-y-0",
                );
                menuIconToggle?.classList.remove("hidden");
                menuIconToggle?.classList.add("block");
                closeIconToggle?.classList.add("hidden");
                closeIconToggle?.classList.remove("block");
                mobileMenuToggle.setAttribute(
                    "aria-label",
                    "Abrir menú de navegación",
                );
            } else {
                // Abrir menú
                mainNav?.classList.remove(
                    "opacity-0",
                    "pointer-events-none",
                    "-translate-y-2",
                );
                mainNav?.classList.add(
                    "opacity-100",
                    "pointer-events-auto",
                    "translate-y-0",
                );
                menuIconToggle?.classList.add("hidden");
                menuIconToggle?.classList.remove("block");
                closeIconToggle?.classList.remove("hidden");
                closeIconToggle?.classList.add("block");
                mobileMenuToggle.setAttribute(
                    "aria-label",
                    "Cerrar menú de navegación",
                );
            }
        });

        // Cerrar el menú al cambiar el tamaño de la ventana (para evitar bugs de resize)
        window.addEventListener("resize", () => {
            if (window.innerWidth >= 768) {
                mainNav?.classList.add(
                    "opacity-0",
                    "pointer-events-none",
                    "-translate-y-2",
                );
                mainNav?.classList.remove(
                    "opacity-100",
                    "pointer-events-auto",
                    "translate-y-0",
                );
                menuIconToggle?.classList.remove("hidden");
                menuIconToggle?.classList.add("block");
                closeIconToggle?.classList.add("hidden");
                closeIconToggle?.classList.remove("block");
                mobileMenuToggle?.setAttribute("aria-expanded", "false");
                mobileMenuToggle?.setAttribute(
                    "aria-label",
                    "Abrir menú de navegación",
                );
            }
        });

        // Lógica para copiar el correo electrónico
        const copyEmailBtn = document.getElementById("copy-email-btn");
        const tooltipCopyText = document.getElementById("tooltip-copy-text");
        const tooltipCopiedText = document.getElementById(
            "tooltip-copied-text",
        );

        copyEmailBtn?.addEventListener("click", async () => {
            const emailToCopy = copyEmailBtn.getAttribute("data-email");
            if (emailToCopy) {
                try {
                    await navigator.clipboard.writeText(emailToCopy);

                    tooltipCopyText?.classList.add("hidden");
                    tooltipCopyText?.classList.remove("flex");
                    tooltipCopiedText?.classList.remove("hidden");
                    tooltipCopiedText?.classList.add("flex");

                    setTimeout(() => {
                        tooltipCopiedText?.classList.add("hidden");
                        tooltipCopiedText?.classList.remove("flex");
                        tooltipCopyText?.classList.remove("hidden");
                        tooltipCopyText?.classList.add("flex");
                    }, 2000);
                } catch (err) {
                    console.error("Error al copiar el email: ", err);
                }
            }
        });
    });
</script>
