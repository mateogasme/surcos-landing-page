---
import PageHeader from '@/components/PageHeader.astro'
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const content = {
  es: {
    title1: 'Acompañamos el desarrollo de tu proyecto.',
    title2: 'Brindamos consultoría estratégica integral.',
  },
  en: {
    title1: 'We support the development of your project.',
    title2: 'We provide comprehensive strategic consulting.',
  },
}

const t = content[lang]
---

<PageHeader title1={t.title1} title2={t.title2} />
