---
import PageHeader from '@/components/PageHeader.astro'
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const content = {
  es: {
    title1: '¿Tenés alguna duda o consulta?',
    title2: 'Encontrá respuestas en nuestras preguntas frecuentes.',
  },
  en: {
    title1: 'Do you have any doubts or inquiries?',
    title2: 'Find answers in our frequently asked questions.',
  },
}

const t = content[lang]
---

<PageHeader title1={t.title1} title2={t.title2} />
