---
import PageHeader from "@/components/PageHeader.astro";
import { getLangFromUrl } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);

const content = {
    es: {
        title: "Formación integral",
        description:
            "En un mundo que atraviesa cambios profundos, concebimos la formación como la herramienta esencial para crear las condiciones óptimas que permitan a los equipos avanzar y crecer.",
    },
    en: {
        title: "Comprehensive Training",
        description:
            "In a world undergoing profound shifts, we envision training as the quintessential tool to foster the ideal conditions for teams to adapt, grow, and move forward.",
    },
};

const t = content[lang];
---

<PageHeader
    title={t.title}
    description={t.description}
    iconWrapperClasses="bg-emerald-500/10 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border-emerald-500/20"
>
    <svg
        slot="icon"
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
        ></path>
    </svg>
</PageHeader>
