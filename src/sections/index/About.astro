---
import { getLangFromUrl, useTranslations } from '@/i18n/utils'
import Modal from '@/components/Modal.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const cards = [
  {
    title: t('cards.about.title'),
    content: t('cards.about.content'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    bgClass: 'bg-blue-500/10 dark:bg-blue-500/20',
    colorClass: 'text-blue-500 dark:text-blue-400',
  },
  {
    title: t('cards.services.title'),
    content: t('cards.services.content'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-grid-icon lucide-layout-grid"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>`,
    bgClass: 'bg-emerald-500/10 dark:bg-emerald-500/20',
    colorClass: 'text-emerald-500 dark:text-emerald-400',
  },
  {
    title: t('cards.vision.title'),
    content: t('cards.vision.content'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`,
    bgClass: 'bg-amber-500/10 dark:bg-amber-500/20',
    colorClass: 'text-amber-500 dark:text-amber-400',
  },
]
---

<section class="w-full mt-24 mb-16 px-6 md:px-0" id="about" aria-labelledby="about-heading">
  <div class="max-w-175 mx-auto">
    <h2 id="about-heading" class="sr-only">{t('hero.about')}</h2>
    <ul class="flex flex-col md:flex-row flex-wrap justify-center gap-6 lg:gap-8 list-none p-0 m-0">
      {
        cards.map((card, index) => (
          <li
            class={`flex flex-col gap-4 p-8 rounded-2xl bg-white/50 dark:bg-zinc-900/50 border border-primary/10 dark:border-white/10 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 w-full ${index === 2 ? '' : 'md:w-[calc(50%-0.75rem)] lg:w-[calc(50%-1rem)]'}`}
          >
            <div
              class={`w-12 h-12 flex items-center justify-center rounded-xl relative ${card.bgClass} ${card.colorClass}`}
              aria-hidden="true"
            >
              <span set:html={card.icon} />
            </div>
            <h3 class="text-xl font-semibold text-primary/90 leading-snug" set:html={card.title} />
            <p class="text-[0.95rem] text-primary/70 leading-relaxed font-normal text-pretty" set:html={card.content} />
          </li>
        ))
      }
    </ul>
  </div>

  <Modal
    id="founder-modal"
    title={t('founder.title')}
    maxWidth="max-w-2xl"
    marginTop="mt-32 md:mt-[15vh]"
  >
    <div
      class="flex flex-col gap-6 text-[0.95rem] leading-relaxed max-h-[60vh] overflow-y-auto pr-2 custom-scrollbar"
    >
      <p set:html={t('founder.p1')} />

      <p set:html={t('founder.p2')} />

      <div class="border-t border-primary/5 pt-5 mt-2">
        <h3 class="font-semibold text-primary mb-4 text-[1rem]">
          {t('founder.current')}
        </h3>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <div class="w-1.5 h-1.5 rounded-full bg-blue-500 mt-2 shrink-0" aria-hidden="true" />
            <p set:html={t('founder.role1')} />
          </li>
          <li class="flex gap-3 items-start">
            <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 shrink-0" aria-hidden="true" />
            <p set:html={t('founder.role2')} />
          </li>
          <li class="flex gap-3 items-start">
            <div class="w-1.5 h-1.5 rounded-full bg-amber-500 mt-2 shrink-0" aria-hidden="true" />
            <p set:html={t('founder.role3')} />
          </li>
          <li class="flex gap-3 items-start">
            <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 mt-2 shrink-0" aria-hidden="true" />
            <p set:html={t('founder.role4')} />
          </li>
          <li class="flex gap-3 items-start">
            <div class="w-1.5 h-1.5 rounded-full bg-purple-500 mt-2 shrink-0" aria-hidden="true" />
            <p set:html={t('founder.role5')} />
          </li>
        </ul>
      </div>
    </div>
  </Modal>
</section>
