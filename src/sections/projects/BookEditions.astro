---
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const content = {
  es: {
    title: 'Ediciones y libros',
    items: [
      {
        title: 'Mapas para la Fiesta',
        desc: 'Nueva edición del libro. Edición propia.',
      },
      {
        title: 'Hacia una Pastoral Juvenil Orgánica',
        desc: 'Edición del texto para reflexión de grupos. Pastoral Juvenil de Zárate-Campana.',
      },
      {
        title: 'Haciendo caminos',
        desc: 'Edición en proceso.',
      },
    ],
  },
  en: {
    title: 'Editions and books',
    items: [
      {
        title: 'Mapas para la Fiesta',
        desc: 'New edition of the book. Self-published.',
      },
      {
        title: 'Hacia una Pastoral Juvenil Orgánica',
        desc: 'Text edition for group reflection. Youth Ministry of Zárate-Campana.',
      },
      {
        title: 'Haciendo caminos',
        desc: 'Edition in progress.',
      },
    ],
  },
}

const t = content[lang]
---

<section class="mb-12">
  <h2 class="text-xl font-bold text-primary/80 mb-6">
    {t.title}
  </h2>
  <ul class="flex flex-col gap-6 list-none p-0 m-0">
    {
      t.items.map((item) => (
        <li class="flex flex-col gap-2 p-8 rounded-2xl bg-white/50 dark:bg-zinc-900/50 border border-primary/10 dark:border-white/10 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 w-full">
          <strong class="text-primary/90 leading-snug text-[1.05rem]">{item.title}</strong>
          <p class="text-[0.95rem] text-primary/70 leading-relaxed font-normal text-pretty m-0">
            {item.desc}
          </p>
        </li>
      ))
    }
  </ul>
</section>
