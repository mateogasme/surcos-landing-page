---
import PageHeader from '@/components/PageHeader.astro'
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)

const content = {
  es: {
    title1: 'Capacitación continua para tu equipo.',
    title2: 'Desarrollamos habilidades y competencias sólidas.',
  },
  en: {
    title1: 'Continuous training for your team.',
    title2: 'We develop solid skills and competencies.',
  },
}

const t = content[lang]
---

<PageHeader title1={t.title1} title2={t.title2} />
